# 在 Google Cloud Console → API 和服务 → 库 中启用：
#   - Maps JavaScript API
#   - Geocoding API
#   - Directions API
# 并为项目绑定结算账号（Maps 平台一般有每月赠额，但仍需启用结算）
# 密钥「应用限制」选「HTTP 引荐来源网址」时，本地请加：http://localhost:3000/*
# 若使用其他端口，引荐来源必须包含该端口（例如 http://localhost:3001/*）
# 若浏览器控制台出现 maps.googleapis.com net::ERR_CONNECTION_TIMED_OUT，
# 多为当前网络无法访问 Google（例如中国大陆），需可访问 Google 的网络环境，或考虑地图备用方案。
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Canonical site URL. Must match the production domain exactly.
NEXT_PUBLIC_SITE_URL=https://www.pickupjp.com

# Public contact and analytics settings.
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_WHATSAPP_DISPLAY_PHONE=+81 90-6399-7223
NEXT_PUBLIC_WHATSAPP_PHONE_NUMBER=819063997223
NEXT_PUBLIC_WECHAT_ID=liyuxuan3512
NEXT_PUBLIC_LINE_ID=
NEXT_PUBLIC_LINE_URL=

# Google Analytics 4 Measurement ID.
# Leave empty until pickupjp.com has its own GA property.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Admin dashboard login.
# Set these in Vercel. Do not commit real production passwords.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
